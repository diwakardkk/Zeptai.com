# Real conversation backend (mybot on Render)
NEXT_PUBLIC_NURSE_API_BASE=https://YOUR-RENDER-API/api/v1
# Server-side base used by the proxy. Set this in your Netlify/hosting env (do NOT expose to client).
NURSE_API_BASE=https://YOUR-RENDER-API/api/v1

# ElevenLabs TTS (used by homepage voice demo)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase (admin)
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Contact
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_RECEIVER_EMAIL=
CONTACT_AUTOREPLY_FROM_NAME=ZeptAI Team

# Blog audio
OPENAI_API_KEY=
OPENAI_BLOG_TTS_MODEL=gpt-4o-mini-tts
OPENAI_BLOG_TTS_VOICE=coral
OPENAI_BLOG_TTS_INSTRUCTIONS=
